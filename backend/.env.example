# ============================================================
# LINKA — Variáveis de Ambiente
# Copiar para .env e preencher com valores reais
# NUNCA commitar o ficheiro .env no Git
# ============================================================

# --- SERVIDOR ---
PORT=3000
NODE_ENV=development

# --- BASE DE DADOS (MySQL) ---
DB_HOST=localhost
DB_PORT=3306
DB_NOME=linka_db
DB_UTILIZADOR=root
DB_PASSWORD=

# --- JWT ---
JWT_SECRET=coloca_aqui_uma_chave_secreta_muito_longa_e_aleatoria
JWT_EXPIRA_EM=15m
JWT_REFRESH_SECRET=outra_chave_secreta_para_refresh_token
JWT_REFRESH_EXPIRA_EM=7d

# --- REDIS ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- UPLOAD ---
UPLOAD_MAX_TAMANHO_MB=5
UPLOAD_PASTA=uploads

# --- CORS ---
FRONTEND_URL=http://localhost:5500

# --- EMAIL (SMTP) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_UTILIZADOR=
EMAIL_PASSWORD=
EMAIL_REMETENTE=Linka <noreply@linka.co.mz>

# --- BCRYPT ---
BCRYPT_ROUNDS=12
